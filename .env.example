# HederaShield Configuration
# Copy to .env and fill in your values

# Hedera Network (testnet, mainnet, previewnet)
HEDERA_SHIELD_HEDERA_NETWORK=testnet

# Hedera Operator Credentials (for enforcement actions)
HEDERA_SHIELD_HEDERA_OPERATOR_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_SHIELD_HEDERA_OPERATOR_KEY=your_ed25519_private_key

# Mirror Node URL
HEDERA_SHIELD_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
HEDERA_SHIELD_MIRROR_NODE_POLL_INTERVAL=10

# Anthropic API Key (for AI-powered analysis)
HEDERA_SHIELD_ANTHROPIC_API_KEY=sk-ant-...

# Compliance Thresholds
HEDERA_SHIELD_LARGE_TRANSFER_THRESHOLD=10000
HEDERA_SHIELD_VELOCITY_WINDOW_SECONDS=3600
HEDERA_SHIELD_VELOCITY_MAX_TRANSFERS=50

# Monitored Token IDs (JSON array)
HEDERA_SHIELD_MONITORED_TOKEN_IDS=["0.0.TOKEN_ID_1"]

# Sanctioned Addresses (JSON array)
HEDERA_SHIELD_SANCTIONED_ADDRESSES=["0.0.BLOCKED_1","0.0.BLOCKED_2"]

# API Settings
HEDERA_SHIELD_API_HOST=0.0.0.0
HEDERA_SHIELD_API_PORT=8000
