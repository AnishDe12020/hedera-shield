# HederaShield testnet configuration template.
# Copy this file to .env.testnet (or .env) and replace placeholders as needed.

HEDERA_SHIELD_HEDERA_NETWORK=testnet  # Hedera network: testnet | mainnet | previewnet
HEDERA_SHIELD_HEDERA_OPERATOR_ID=0.0.YOUR_OPERATOR_ACCOUNT_ID  # Operator account ID (0.0.x format)
HEDERA_SHIELD_HEDERA_OPERATOR_KEY=YOUR_ED25519_PRIVATE_KEY  # ED25519 private key string placeholder

HEDERA_SHIELD_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com  # Mirror Node base URL
HEDERA_SHIELD_MIRROR_NODE_POLL_INTERVAL=10  # Poll cadence in seconds (integer)

HEDERA_SHIELD_ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_OR_EMPTY  # Optional; keep placeholder if unused
HEDERA_SHIELD_AI_MODEL=claude-sonnet-4-20250514  # Claude model ID

HEDERA_SHIELD_LARGE_TRANSFER_THRESHOLD=10000  # Large-transfer rule threshold (float)
HEDERA_SHIELD_VELOCITY_WINDOW_SECONDS=3600  # Velocity window duration (integer seconds)
HEDERA_SHIELD_VELOCITY_MAX_TRANSFERS=50  # Max transfers allowed in velocity window (integer)

HEDERA_SHIELD_API_HOST=0.0.0.0  # API bind host
HEDERA_SHIELD_API_PORT=8000  # API bind port

HEDERA_SHIELD_MONITORED_TOKEN_IDS=["0.0.YOUR_TOKEN_ID"]  # JSON array of token IDs to monitor
HEDERA_SHIELD_SANCTIONED_ADDRESSES=["0.0.YOUR_SANCTIONED_ACCOUNT_ID"]  # JSON array of Hedera account IDs
